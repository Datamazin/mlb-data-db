# Copy to .env and fill in values. Never commit .env.

# Azure Storage (for distribution layer — not needed for local dev)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_PREFIX=mlb-club-

# Pipeline settings
MLB_API_BASE_URL=https://statsapi.mlb.com/api
MLB_API_RATE_LIMIT_RPS=8
MLB_API_MAX_RETRIES=5

# Local paths (override for non-default layouts)
BRONZE_PATH=data/bronze
GOLD_DB_PATH=data/gold/mlb.duckdb

# Logging
LOG_LEVEL=INFO
